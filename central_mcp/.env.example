# ==========================================
# SmartHub Central MCP Server Configuration
# ==========================================

# The base URL of your FastAPI API Gateway (hub_backend)
# Default fallback in code is http://localhost:8000 if omitted
BACKEND_URL=http://localhost:8000
BACKEND_TIMEOUT_MS=120000

# The secure token required to execute Admin-level orchestration commands.
# NOTE: During local development, paste your active admin JWT here.
# When the VS Code extension is fully integrated, the IDE will pass this dynamically.
DEV_ADMIN_TOKEN=your_local_admin_jwt_or_test_token_here
